# Required GitHub Secrets for deployment
# Add these in Settings > Secrets and variables > Actions
# Repo: https://github.com/nsharma1972/trinitybps-website/settings/secrets/actions

# CapRover — prod (captain.app.trinitybps.com)
CAPROVER_URL=https://captain.app.trinitybps.com
CAPROVER_PASSWORD=

# GHCR pull token (for CapRover to pull images from GitHub Container Registry)
# Create a GitHub Personal Access Token with read:packages scope
GHCR_PULL_TOKEN=

# App environment variables (injected into the container)
RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@trinitybps.com
